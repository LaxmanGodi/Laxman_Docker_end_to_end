# The Blueprint: Custom Resource Definition (CRD)
# This script tells Kubernetes, "Hey, I am introducing a new type of object called a Database." 
# Without this, Kubernetes won't understand your custom commands.


apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  # The name must follow the pattern: <plural>.<group>
  name: databases.stable.example.com
spec:
  # This is the 'domain' for your custom resource
  group: stable.example.com
  versions:
    - name: v1
      served: true
      storage: true
      schema:
        openAPIV3Schema:
          type: object
          properties:
            spec:
              type: object
              properties:
                # We define what inputs a user can provide
                engine: {type: string}      # e.g., mysql, postgres
                version: {type: string}     # e.g., 8.0
                storageGb: {type: integer}  # e.g., 20
  # Scope can be 'Namespaced' (specific to a project) or 'Cluster' (global)
  scope: Namespaced
  names:
    plural: databases
    singular: database
    kind: Database
    shortNames:
      - db
